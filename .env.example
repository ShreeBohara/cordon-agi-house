# CORDON environment — names only. Copy to .env and fill locally. NEVER commit .env.

# --- Daytona (sandboxes: create / freeze / kill / network-block) ---
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_TARGET=us

# --- OpenAI (Agents SDK; note: openai v2.x required, v1.x unsupported) ---
OPENAI_API_KEY=

# --- 1Password (Service Account; token shown once, starts with ops_) ---
OP_SERVICE_ACCOUNT_TOKEN=
# The one hero credential the broker resolves for healthy agents / denies for tainted ones:
OP_PRODUCTION_SECRET_REF=op://Production/Deploy Key/credential

# --- CORDON control plane ---
# Tools call back into the control plane so EVERY tool call routes through the proxy.
CORDON_CONTROL_PLANE_URL=http://127.0.0.1:8000
# "1" = drive the dashboard from demo/scenario.json instead of the live swarm.
CORDON_DEMO_MODE=1
